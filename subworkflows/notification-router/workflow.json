                                                            "conditions":  [
                                                                               {
                                                                                   "id":  "send-email-condition",
                                                                                   "leftValue":  "={{ $json.sendToEmail }}",
                                                                                   "rightValue":  true,
                                                                                   "operator":  {
                                                                                                    "type":  "boolean",
                                                                                                    "operation":  "equal"
                                                                                                }
                                                                               }
                                                                           ],
                                                            "combinator":  "and"
                                                        }
