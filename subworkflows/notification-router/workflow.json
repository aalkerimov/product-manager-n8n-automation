                                                                                   "operator":  {
                                                                                                    "type":  "boolean",
                                                                                                    "operation":  "equal"
                                                                                                }
                                                                               }
                                                                           ],
                                                            "combinator":  "and"
                                                        }
                                     },
                      "id":  "check-telegram",
