                      "maxTries":  3,
                      "waitBetweenTries":  1000
                  },
                  {
                      "parameters":  {
                                         "sendTo":  "={{ $json.emailTo }}",
                                         "subject":  "={{ $json.formattedTitle }}",
                                         "message":  "\u003chtml\u003e\u003cbody style=\"font-family: Arial, sans-serif; max-width: 640px; margin: 0 auto; padding: 20px;\"\u003e\n\u003ch2\u003e{{ $json.formattedTitle }}\u003c/h2\u003e\n\u003cdiv style=\"white-space: pre-wrap; font-size: 15px; line-height: 1.6;\"\u003e{{ $json.body }}\u003c/div\u003e\n\u003chr style=\"margin-top: 30px;\"\u003e\n\u003cp style=\"color: #aaa; font-size: 12px;\"\u003eSent by n8n Product \u0026 Founder Automation OS at {{ new Date().toISOString() }}\u003c/p\u003e\n\u003c/body\u003e\u003c/html\u003e",
                                         "options":  {

                                                     }
                                     },
                      "id":  "send-email",
                      "name":  "Send Email",
                      "type":  "n8n-nodes-base.emailSend",
                      "typeVersion":  2.1,
                      "position":  [
                                       900,
                                       200
                                   ],
                      "credentials":  {
                                          "smtp":  {
                                                       "id":  "SMTP_CREDENTIAL_ID",
                                                       "name":  "SMTP Email"
                                                   }
                                      },
                      "retryOnFail":  true,
                      "maxTries":  3,
                      "waitBetweenTries":  1000
                  },
                  {
                      "parameters":  {
                                         "chatId":  "={{ $json.telegramChatId }}",
                                         "text":  "*{{ $json.formattedTitle }}*\n\n{{ $json.body }}",
                                         "additionalFields":  {
                                                                  "parse_mode":  "Markdown"
                                                              }
                                     },
                      "id":  "send-telegram",
                      "name":  "Send Telegram",
                      "type":  "n8n-nodes-base.telegram",
                      "typeVersion":  1.2,
                      "position":  [
                                       900,
                                       440
                                   ],
                      "credentials":  {
                                          "telegramApi":  {
                                                              "id":  "TELEGRAM_CREDENTIAL_ID",
                                                              "name":  "Telegram API"
                                                          }
                                      },
                      "retryOnFail":  true,
                      "maxTries":  3,
                      "waitBetweenTries":  1000
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Collect results from all channels and return a summary\nconst input = $(\u0027Prepare Notification\u0027).first().json;\n\nreturn [{\n  json: {\n    sent: true,\n    channels: [\n      ...(input.sendToSlack ? [\u0027slack\u0027] : []),\n      ...(input.sendToEmail ? [\u0027email\u0027] : []),\n      ...(input.sendToTelegram ? [\u0027telegram\u0027] : []),\n    ],\n    title: input.title,\n    urgency: input.urgency,\n    sentAt: new Date().toISOString(),\n  }\n}];"
                                     },
                      "id":  "summarize-sent",
                      "name":  "Return Sent Summary",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1120,
                                       200
                                   ]
                  }
              ],
