                                                           "__rl":  true,
                                                           "mode":  "expression",
                                                           "value":  "={{ $json.slackChannel }}"
                                                       },
                                         "text":  "*{{ $json.formattedTitle }}*\n\n{{ $json.body }}",
                                         "otherOptions":  {
                                                              "mrkdwn":  true
                                                          }
