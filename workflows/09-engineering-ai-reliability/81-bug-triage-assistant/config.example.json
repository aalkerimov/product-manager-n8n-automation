{
  "_comment": "config.example.json for Bug Triage Assistant",
  "workflow_id": "81-bug-triage-assistant",
  "workflow_name": "Bug Triage Assistant",
  "collection": "09-engineering-ai-reliability",
  "status": "beta",
  "configuration": {
    "BUG_TRIAGE_EMAIL_TO": { "default": "", "description": "Engineering team recipients", "required": "Required" },
    "BUG_TRIAGE_APPROVER_EMAIL": { "default": "", "description": "PM approver. Defaults to BUG_TRIAGE_EMAIL_TO.", "required": "Optional" },
    "AI_MODEL": { "default": "gpt-4o-mini", "description": "LLM model (low temperature 0.1 for consistent severity classification)", "required": "Required" },
    "OPENAI_BASE_URL": { "default": "https://api.openai.com", "description": "LLM base URL", "required": "Optional" },
    "NOTIFICATION_EMAIL_FROM": { "default": "automation@example.com", "description": "Sender address", "required": "Optional" }
  },
  "n8n_credentials_required": [
    { "name": "YOUR_OPENAI_CREDENTIAL", "type": "httpHeaderAuth", "required": true, "purpose": "LLM bug severity classification" },
    { "name": "YOUR_SMTP_CREDENTIAL", "type": "smtp", "required": true, "purpose": "Approval and engineering notification" }
  ],
  "webhook_path": "/webhook/triage-bug",
  "webhook_method": "POST"
}
