{
  "_comment": "config.example.json for Release Notes Generator",
  "workflow_id": "65-release-notes-generator",
  "workflow_name": "Release Notes Generator",
  "collection": "07-roadmap-planning",
  "status": "beta",
  "configuration": {
    "RELEASE_EMAIL_TO": { "default": "", "description": "Approver (PM) email address", "required": "Required" },
    "RELEASE_DISTRIBUTION_EMAIL": { "default": "", "description": "Publishing destination — team, users, changelog. Defaults to RELEASE_EMAIL_TO if not set.", "required": "Optional" },
    "AI_MODEL": { "default": "gpt-4o-mini", "description": "LLM model", "required": "Required" },
    "OPENAI_BASE_URL": { "default": "https://api.openai.com", "description": "LLM base URL", "required": "Optional" },
    "NOTIFICATION_EMAIL_FROM": { "default": "automation@acme-analytics.com", "description": "Sender address", "required": "Optional" }
  },
  "n8n_credentials_required": [
    { "name": "YOUR_OPENAI_CREDENTIAL", "type": "httpHeaderAuth", "required": true, "purpose": "LLM technical-to-user translation" },
    { "name": "YOUR_SMTP_CREDENTIAL", "type": "smtp", "required": true, "purpose": "Approval and publishing" }
  ],
  "webhook_path": "/webhook/generate-release-notes",
  "webhook_method": "POST"
}
