  "n8n_credentials_required": [
    { "name": "YOUR_OPENAI_CREDENTIAL", "type": "httpHeaderAuth", "required": true, "purpose": "Personalised outreach drafts" },
    { "name": "YOUR_SMTP_CREDENTIAL", "type": "smtp", "required": true, "purpose": "Draft delivery to founder" }
  ],
  "schedule": "Every Monday at 08:00",
