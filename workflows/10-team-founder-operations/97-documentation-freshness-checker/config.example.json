{
  "_comment": "config.example.json for Documentation Freshness Checker",
  "workflow_id": "97-documentation-freshness-checker",
  "workflow_name": "Documentation Freshness Checker",
  "collection": "10-team-founder-operations",
  "status": "beta",
  "configuration": {
    "DOCS_EMAIL_TO": { "default": "", "description": "Doc owners / team recipients", "required": "Required" },
    "DOCS_APPROVER_EMAIL": { "default": "", "description": "Manager approver. Defaults to DOCS_EMAIL_TO.", "required": "Optional" },
    "NOTIFICATION_EMAIL_FROM": { "default": "automation@example.com", "description": "Sender address", "required": "Optional" }
  },
  "n8n_credentials_required": [
    { "name": "YOUR_SMTP_CREDENTIAL", "type": "smtp", "required": true, "purpose": "Approval gate and owner notifications" }
  ],
  "ai_required": false,
  "schedule": "Every Monday at 09:00",
  "severity_thresholds": { "critical": "staleness_ratio >= 3", "warning": "staleness_ratio >= 2", "stale": "days_since_update > stale_threshold_days" }
}
