{
  "_comment": "config.example.json for Survey Response Analyser",
  "workflow_id": "72-survey-response-analyser",
  "workflow_name": "Survey Response Analyser",
  "collection": "08-user-research-discovery",
  "status": "beta",
  "configuration": {
    "SURVEY_EMAIL_TO": { "default": "", "description": "Product team recipients", "required": "Required" },
    "SURVEY_APPROVER_EMAIL": { "default": "", "description": "PM approver. Defaults to SURVEY_EMAIL_TO.", "required": "Optional" },
    "AI_MODEL": { "default": "gpt-4o-mini", "description": "LLM model", "required": "Required" },
    "OPENAI_BASE_URL": { "default": "https://api.openai.com", "description": "LLM base URL", "required": "Optional" },
    "NOTIFICATION_EMAIL_FROM": { "default": "automation@example.com", "description": "Sender address", "required": "Optional" }
  },
  "n8n_credentials_required": [
    { "name": "YOUR_OPENAI_CREDENTIAL", "type": "httpHeaderAuth", "required": true, "purpose": "LLM theme analysis" },
    { "name": "YOUR_SMTP_CREDENTIAL", "type": "smtp", "required": true, "purpose": "Approval and product team delivery" }
  ],
  "webhook_path": "/webhook/analyse-survey",
  "webhook_method": "POST",
  "notes": "Anonymise open-text responses if PII is present before sending to LLM."
}
