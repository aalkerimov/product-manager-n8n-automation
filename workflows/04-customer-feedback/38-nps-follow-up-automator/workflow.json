{
  "meta": { "id": "38", "name": "NPS Follow-up Automator", "description": "Automatically send personalised follow-up messages to NPS detractors (offer help) and promoters (ask for review/referral) within 24 hours of response.", "category": "Customer & Feedback", "status": "beta", "version": "1.0.0", "testedN8nVersion": "2.30.0", "difficulty": "beginner", "setupTime": "10 min", "requiredIntegrations": ["OpenAI API", "SMTP Email"], "optionalIntegrations": ["Typeform", "Intercom"], "triggerType": "webhook", "aiRequired": true, "humanApproval": false, "tags": ["NPS", "follow-up", "customer-success", "automation"] },
  "name": "38 – NPS Follow-up Automator",
  "nodes": [
    { "id": "n-setup", "name": "⚙️ SETUP", "type": "n8n-nodes-base.stickyNote", "typeVersion": 1, "position": [-480, -320], "parameters": { "content": "## 38 — NPS Follow-up Automator\n\nHook this into your NPS survey tool (Typeform, Delighted, etc.) via webhook.\n\n**Required:** OpenAI API, SMTP Email\n- EMAIL_FROM: your product/CS email address\n- NPS_DETRACTOR_MESSAGE_CONTEXT: brief product context for AI follow-up generation\n- NPS_PROMOTER_REVIEW_URL: link to your App Store or G2 page\n\n**Status:** Beta.", "height": 280, "width": 380, "color": 7 } },
    { "id": "n-webhook", "name": "Webhook — NPS Response", "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [-200, -20], "parameters": { "path": "nps-followup", "httpMethod": "POST", "responseMode": "onReceived", "options": {} }, "webhookId": "nps-followup-webhook" },
    { "id": "n-manual", "name": "Manual Trigger", "type": "n8n-nodes-base.manualTrigger", "typeVersion": 1, "position": [-200, 100], "parameters": {} },
    { "id": "n-normalise", "name": "Normalise NPS Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [60, 40], "parameters": { "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst score = parseInt(body.score || body.nps_score || 0);\nconst category = score >= 9 ? 'promoter' : score >= 7 ? 'passive' : 'detractor';\nreturn [{ json: { email: body.email || '', name: body.name || body.respondent_name || 'Customer', score, comment: body.comment || body.feedback || '', segment: body.segment || '', category, responded_at: new Date().toISOString() } }];" } },
    { "id": "n-route", "name": "Route by Category", "type": "n8n-nodes-base.switch", "typeVersion": 3.3, "position": [300, 40], "parameters": { "mode": "expression", "output": "={{ $json.category }}", "rules": { "rules": [{ "outputKey": "promoter", "conditions": { "conditions": [{ "leftValue": "={{ $json.category }}", "rightValue": "promoter", "operator": { "type": "string", "operation": "equals" } }] } }, { "outputKey": "detractor", "conditions": { "conditions": [{ "leftValue": "={{ $json.category }}", "rightValue": "detractor", "operator": { "type": "string", "operation": "equals" } }] } }] }, "options": {} } },
    { "id": "n-gen-detractor", "name": "Write Detractor Follow-up (AI)", "type": "@n8n/n8n-nodes-langchain.openAi", "typeVersion": 1.7, "position": [540, -40], "parameters": { "resource": "text", "operation": "message", "model": { "__rl": true, "value": "={{ $env.AI_MODEL_FAST || 'gpt-4o-mini' }}", "mode": "id" }, "messages": { "values": [{ "role": "system", "content": "Write a short, empathetic, genuine follow-up email to an NPS detractor. Acknowledge their feedback, offer help. Do not be defensive. Maximum 80 words." }, { "role": "user", "content": "Customer: {{ $json.name }}\nScore: {{ $json.score }}/10\nFeedback: {{ $json.comment || 'No comment provided' }}\nProduct context: {{ $env.NPS_DETRACTOR_MESSAGE_CONTEXT || 'a SaaS product' }}\n\nWrite only the email body (no subject line)." }] }, "options": {} }, "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI API" } } },
    { "id": "n-gen-promoter", "name": "Write Promoter Follow-up (AI)", "type": "@n8n/n8n-nodes-langchain.openAi", "typeVersion": 1.7, "position": [540, 120], "parameters": { "resource": "text", "operation": "message", "model": { "__rl": true, "value": "={{ $env.AI_MODEL_FAST || 'gpt-4o-mini' }}", "mode": "id" }, "messages": { "values": [{ "role": "system", "content": "Write a short, warm, authentic thank-you email to an NPS promoter. Celebrate their experience and include a natural ask for a review. Maximum 80 words." }, { "role": "user", "content": "Customer: {{ $json.name }}\nScore: {{ $json.score }}/10\nFeedback: {{ $json.comment || 'No comment provided' }}\nReview URL: {{ $env.NPS_PROMOTER_REVIEW_URL || 'https://g2.com' }}\n\nWrite only the email body (no subject line)." }] }, "options": {} }, "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI API" } } },
    { "id": "n-send-detractor", "name": "Send Detractor Email", "type": "n8n-nodes-base.emailSend", "typeVersion": 2.1, "position": [780, -40], "parameters": { "fromEmail": "={{ $env.EMAIL_FROM || 'noreply@yourcompany.com' }}", "toEmail": "={{ $('Normalise NPS Response').first().json.email }}", "subject": "Thank you for your feedback — we want to help", "emailType": "text", "message": "={{ $input.first().json.message?.content || '' }}", "options": {} }, "credentials": { "smtp": { "id": "SMTP_CREDENTIAL_ID", "name": "SMTP Email" } } },
    { "id": "n-send-promoter", "name": "Send Promoter Email", "type": "n8n-nodes-base.emailSend", "typeVersion": 2.1, "position": [780, 120], "parameters": { "fromEmail": "={{ $env.EMAIL_FROM || 'noreply@yourcompany.com' }}", "toEmail": "={{ $('Normalise NPS Response').first().json.email }}", "subject": "Thank you for the kind words! ❤️", "emailType": "text", "message": "={{ $input.first().json.message?.content || '' }}", "options": {} }, "credentials": { "smtp": { "id": "SMTP_CREDENTIAL_ID", "name": "SMTP Email" } } }
  ],
  "connections": {
    "Webhook — NPS Response": { "main": [[{ "node": "Normalise NPS Response", "type": "main", "index": 0 }]] },
