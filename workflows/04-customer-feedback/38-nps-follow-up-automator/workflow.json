    "Normalise NPS Response": { "main": [[{ "node": "Route by Category", "type": "main", "index": 0 }]] },
    "Route by Category": { "main": [[{ "node": "Write Promoter Follow-up (AI)", "type": "main", "index": 0 }], [], [{ "node": "Write Detractor Follow-up (AI)", "type": "main", "index": 0 }]] },
    "Write Detractor Follow-up (AI)": { "main": [[{ "node": "Send Detractor Email", "type": "main", "index": 0 }]] },
