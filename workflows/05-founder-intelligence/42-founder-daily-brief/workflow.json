    { "id": "n-metrics", "name": "Load Metrics", "type": "n8n-nodes-base.googleSheets", "typeVersion": 4.5, "position": [60, -20], "parameters": { "operation": "read", "documentId": { "__rl": true, "value": "={{ $env.BRIEF_SHEET_ID }}", "mode": "id" }, "sheetName": { "__rl": true, "value": "Metrics", "mode": "name" }, "options": {} }, "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets OAuth2" } } },
    { "id": "n-blockers", "name": "Load Blockers", "type": "n8n-nodes-base.googleSheets", "typeVersion": 4.5, "position": [60, 100], "parameters": { "operation": "read", "documentId": { "__rl": true, "value": "={{ $env.BRIEF_SHEET_ID }}", "mode": "id" }, "sheetName": { "__rl": true, "value": "Blockers", "mode": "name" }, "options": {} }, "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets OAuth2" } } },
    { "id": "n-decisions", "name": "Load Open Decisions", "type": "n8n-nodes-base.googleSheets", "typeVersion": 4.5, "position": [60, 220], "parameters": { "operation": "read", "documentId": { "__rl": true, "value": "={{ $env.BRIEF_SHEET_ID }}", "mode": "id" }, "sheetName": { "__rl": true, "value": "Decisions", "mode": "name" }, "options": {} }, "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets OAuth2" } } },
    { "id": "n-compile", "name": "Compile Brief (AI)", "type": "@n8n/n8n-nodes-langchain.openAi", "typeVersion": 1.7, "position": [300, 100], "parameters": { "resource": "text", "operation": "message", "model": { "__rl": true, "value": "={{ $env.AI_MODEL_SMART || 'gpt-4o' }}", "mode": "id" }, "messages": { "values": [{ "role": "system", "content": "You are a sharp executive assistant. Compile a concise founder daily brief. Be direct. Surface only what matters. Maximum 400 words. Return JSON only." }, { "role": "user", "content": "Today: {{ new Date().toDateString() }}\n\nKey Metrics:\n{{ JSON.stringify($('Load Metrics').all().map(i=>i.json).slice(0,10), null, 2) }}\n\nTeam Blockers:\n{{ JSON.stringify($('Load Blockers').all().map(i=>i.json), null, 2) }}\n\nOpen Decisions:\n{{ JSON.stringify($('Load Open Decisions').all().map(i=>i.json), null, 2) }}\n\nReturn JSON:\n{ \"date\": str, \"headline\": str, \"metrics_summary\": str, \"top_blocker\": str|null, \"decision_of_the_day\": str|null, \"watch_list\": [str], \"full_brief\": str }" }] }, "options": {} }, "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI API" } } },
    { "id": "n-parse", "name": "Parse Brief", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [540, 100], "parameters": { "jsCode": "let brief;\ntry { brief = JSON.parse(($input.first().json.message?.content||'{}').replace(/```json|```/g,'').trim()); } catch { brief = {}; }\nreturn [{ json: { generated_at: new Date().toISOString(), ...brief } }];" } },
    { "id": "n-email", "name": "Email Daily Brief", "type": "n8n-nodes-base.emailSend", "typeVersion": 2.1, "position": [780, 100], "parameters": { "fromEmail": "={{ $env.EMAIL_FROM || 'noreply@yourcompany.com' }}", "toEmail": "={{ $env.NOTIFICATION_EMAIL_TO }}", "subject": "☀️ {{ $json.date || new Date().toDateString() }}: {{ $json.headline || 'Your Daily Brief' }}", "emailType": "text", "message": "{{ $json.full_brief }}\n\n{{ $json.decision_of_the_day ? '📌 DECIDE TODAY: ' + $json.decision_of_the_day : '' }}\n{{ $json.top_blocker ? '🚧 TOP BLOCKER: ' + $json.top_blocker : '' }}\n\nWATCH:\n{{ ($json.watch_list||[]).map(w=>`→ ${w}`).join('\\n') }}\n", "options": {} }, "credentials": { "smtp": { "id": "SMTP_CREDENTIAL_ID", "name": "SMTP Email" } } }
