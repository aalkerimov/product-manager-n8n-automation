# =============================================================================
# Product & Founder Automation OS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- General ---
COMPANY_NAME="Acme Inc"
TIMEZONE="UTC"
N8N_VERSION="2.30.0"

# --- AI Provider (OpenAI-compatible) ---
# Required for all AI-powered workflows
AI_PROVIDER_BASE_URL="https://api.openai.com/v1"
AI_MODEL_FAST="gpt-4o-mini"
AI_MODEL_SMART="gpt-4o"
AI_MAX_TOKENS="2048"
AI_TEMPERATURE="0.3"
# Store API key in n8n credentials — do NOT put it here
# AI_API_KEY is managed inside n8n as "OpenAI API" credential

# --- Notification: Basic Stack (Email / Telegram) ---
NOTIFICATION_EMAIL_TO="team@example.com"
NOTIFICATION_EMAIL_FROM="n8n-bot@example.com"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
TELEGRAM_BOT_TOKEN_SECRET="n8n-credential-name:TelegramBotToken"

# --- Notification: Advanced Stack (Slack) ---
SLACK_CHANNEL_ALERTS="#product-alerts"
SLACK_CHANNEL_BRIEFS="#weekly-brief"
SLACK_CHANNEL_COMPETITORS="#competitor-intel"
SLACK_BOT_TOKEN_SECRET="n8n-credential-name:SlackBotToken"

# --- Storage: Basic Stack ---
# Google Sheets document IDs (visible in sheet URL)
GSHEET_FEEDBACK_DOC_ID="YOUR_GOOGLE_SHEET_ID"
GSHEET_FEEDBACK_SHEET_NAME="Feedback"
GSHEET_COMPETITOR_DOC_ID="YOUR_GOOGLE_SHEET_ID"
GSHEET_COMPETITOR_SHEET_NAME="Snapshots"
GSHEET_BRIEF_DOC_ID="YOUR_GOOGLE_SHEET_ID"
GSHEET_BRIEF_SHEET_NAME="Briefs"

# --- Storage: Advanced Stack (PostgreSQL) ---
PG_HOST="localhost"
PG_PORT="5432"
PG_DATABASE="automation_os"
PG_USER="automation_os"
# PG_PASSWORD is managed inside n8n as "Postgres" credential

# --- Issue Tracker (Advanced) ---
# Choose one: LINEAR or JIRA
ISSUE_TRACKER="LINEAR"
LINEAR_API_KEY_SECRET="n8n-credential-name:LinearAPIKey"
LINEAR_TEAM_ID="YOUR_LINEAR_TEAM_ID"
JIRA_BASE_URL="https://yourcompany.atlassian.net"
JIRA_PROJECT_KEY="PROD"
JIRA_API_SECRET="n8n-credential-name:JiraAPIKey"

# --- GitHub (Advanced) ---
GITHUB_OWNER="your-org"
GITHUB_REPO="your-repo"
GITHUB_TOKEN_SECRET="n8n-credential-name:GitHubToken"

# --- Customer Feedback Brain ---
FEEDBACK_WEBHOOK_PATH="/webhook/feedback"
FEEDBACK_CLASSIFICATION_THRESHOLD="0.6"
FEEDBACK_DEDUP_WINDOW_HOURS="168"
FEEDBACK_REPORT_SCHEDULE="0 9 * * 1"
FEEDBACK_URGENT_LABEL="urgent"
FEEDBACK_SEGMENTS="enterprise,growth,startup,consumer"
FEEDBACK_PRODUCT_AREAS="onboarding,billing,core-product,integrations,performance,support"

# --- Competitor Change Monitor ---
COMPETITOR_CHECK_SCHEDULE="0 */6 * * *"
COMPETITOR_CHANGE_IMPORTANCE_THRESHOLD="6"
COMPETITOR_DIFF_MIN_CHARS="100"
COMPETITOR_PAGES_CONFIG='[
  {"company":"Acme Rival","url":"https://example-rival.com/pricing","type":"pricing"},
  {"company":"Acme Rival","url":"https://example-rival.com/changelog","type":"changelog"}
]'

# --- Weekly Product Brief ---
BRIEF_SCHEDULE="0 8 * * 5"
BRIEF_PERIOD_DAYS="7"
BRIEF_GITHUB_SINCE_DAYS="7"
BRIEF_INCLUDE_GITHUB="true"
BRIEF_INCLUDE_ANALYTICS="false"
BRIEF_ANALYTICS_SOURCE="manual"
BRIEF_RECIPIENTS="cto@example.com,product@example.com"
